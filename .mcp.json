{
  "mcpServers": {
    "spec-workflow": {
      "command": "bunx",
      "args": ["spec-workflow-mcp", "."]
    },
    "supabase": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$env:SUPABASE_ACCESS_TOKEN = [Environment]::GetEnvironmentVariable('SUPABASE_ACCESS_TOKEN', 'User'); npx -y @supabase/mcp-server-supabase --project-ref mlcptrkvkseyqxxlfcme"
      ]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "-p",
        "3.13",
        "--from",
        "serena-agent",
        "serena",
        "start-mcp-server",
        "--project",
        "E:/code/jjg-admin-react-github",
        "--context=codex"
      ]
    }
  }
}
