{
  "mcpServers": {
    "spec-workflow": {
      "command": "npx",
      "args": ["--no-install", "spec-workflow-mcp", "."]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "supabase": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$env:SUPABASE_ACCESS_TOKEN = [Environment]::GetEnvironmentVariable('SUPABASE_ACCESS_TOKEN', 'User'); npx -y @supabase/mcp-server-supabase --project-ref mlcptrkvkseyqxxlfcme"
      ]
    },
    "serena": {
      "command": "C:/Users/Administrator/.local/bin/uvx.exe",
      "args": [
        "-p",
        "3.13",
        "--from",
        "serena-agent",
        "serena",
        "start-mcp-server",
        "--project",
        "E:/code/jjg-admin-react-github",
        "--context=codex"
      ]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    }
  }
}
