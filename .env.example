# Environment variable template

# Supabase
VITE_REACT_APP_SUPABASE_URL=your_supabase_project_url
VITE_REACT_APP_SUPABASE_KEY=your_supabase_anon_key

# Optional: force Supabase Edge Function execution region.
# Try ap-southeast-1 (Singapore) first, then ap-northeast-1 (Tokyo).
VITE_SUPABASE_FUNCTION_REGION=ap-southeast-1

# Syney store-in report proxy.
# Local development can leave this empty; Vite dev server uses the local proxy.
# Static hosting such as Aliyun OSS can leave this empty and use Supabase Edge
# Function, or point this to a separate backend endpoint.
# Example: https://api.example.com/api/syney-store-report
VITE_SYNEY_STORE_REPORT_API_URL=

# Optional remote database URL for CLI/scripts only. Do not commit real secrets.
SUPABASE_DB_URL=

# Server-side only: configure these in the backend/proxy environment, not in frontend
# public runtime variables.
SYNEY_SCM_USERNAME=your_syney_scm_username
SYNEY_SCM_PASSWORD=your_syney_scm_password
# Optional: use the MD5 value required by the Syney login API instead of plaintext.
SYNEY_SCM_PASSWORD_MD5=

# Youmai SRM purchase order proxy.
# Keep these server-side only. Do not expose credentials through VITE_* vars.
YOUMAI_SRM_USERNAME=your_youmai_srm_username
YOUMAI_SRM_PASSWORD=your_youmai_srm_password
# Optional: point the frontend to a deployed proxy. Same-origin /api is used by default.
VITE_YOUMAI_PURCHASE_ORDER_API_URL=
