{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "spec-workflow": {
      "type": "local",
      "command": ["npx", "--no-install", "spec-workflow-mcp", "."],
      "enabled": true
    },
    "supabase": {
      "type": "local",
      "command": [
        "powershell",
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$env:SUPABASE_ACCESS_TOKEN = [Environment]::GetEnvironmentVariable('SUPABASE_ACCESS_TOKEN', 'User'); npx -y @supabase/mcp-server-supabase --project-ref mlcptrkvkseyqxxlfcme"
      ],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "C:/Users/Administrator/.local/bin/uvx.exe",
        "-p",
        "3.13",
        "--from",
        "serena-agent",
        "serena",
        "start-mcp-server",
        "--project",
        "E:/code/jjg-admin-react-github",
        "--context=codex"
      ],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    }
  }
}
