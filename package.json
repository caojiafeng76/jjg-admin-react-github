{
  "name": "jjg-admin-react",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "check:bundle": "bun scripts/check-bundle-budget.mjs",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "preview": "vite preview",
    "ai:doctor": "bun scripts/ai-doctor.mjs",
    "mcp:serena": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-serena-singleton.ps1",
    "graphify:build": "graphify build .",
    "graphify:update": "graphify auto-update .",
    "spec": "bun scripts/spec-workflow-cli.mjs",
    "spec:list": "bun scripts/spec-workflow-cli.mjs list --json",
    "spec:status": "bun scripts/spec-workflow-cli.mjs status",
    "spec:instructions": "bun scripts/spec-workflow-cli.mjs instructions",
    "db:doctor": "bun scripts/supabase-db-doctor.mjs",
    "db:push": "bun scripts/supabase-db-push.mjs",
    "db:push:api": "bun scripts/supabase-db-push-api.mjs",
    "db:push:dry-run": "bun scripts/supabase-db-push.mjs --dry-run",
    "db:query": "bun scripts/supabase-db-query.mjs",
    "db:types": "supabase gen types --lang typescript --linked --schema public > src/services/database.types.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@heroicons/react": "2.2.0",
    "@supabase/supabase-js": "^2.108.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "antd": "6.3.7",
    "dayjs": "^1.11.21",
    "immer": "^11.1.8",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "pinyin-pro": "^3.28.1",
    "qr-scanner": "^1.4.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-qr-code": "2.0.21",
    "react-router-dom": "^7.17.0",
    "supabase": "^2.105.0",
    "xlsx-js-style": "^1.2.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@ant-design/cli": "^6.4.4",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "spec-workflow-mcp": "^1.0.8",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.12",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-mkcert": "^2.1.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "dompurify": "3.4.12"
  }
}
